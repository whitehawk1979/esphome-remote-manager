# ESPHome Remote Manager Configuration

# ESPHome Remote Builder API
ESPHOME_API_URL=http://192.168.1.64:7123
ESPHOME_API_USER=esphome
ESPHOME_API_PASS=esphome
ESPHOME_DASHBOARD_URL=http://192.168.1.64:6052

# MQTT Broker (for Home Assistant discovery)
MQTT_BROKER=192.168.1.43
MQTT_PORT=1883
MQTT_USER=mqtt
MQTT_PASS=your_mqtt_password

# Device Configuration
DEVICE_NAME=ESPHome Remote Manager
DEVICE_ID=esphome_remote_manager

# Server Port
PORT=8080